{
  "CatFactApi": {
    "BaseUrl": "https://catfact.ninja/",
    "FactEndpoint": "fact",
    "TimeoutSeconds": 15
  },
  "Storage": {
    "DataDirectory": "Data",
    "FactsFileName": "catfacts.txt",
	"ResultsFileName": "results.txt",
    "CrudLogFileName": "CRUD.log.txt",
    "ErrorLogFileName": "log.txt",
    "AllowedFileExtensions": [ ".txt" ],
    "MaxFactLength": 1000,
    "MaxManualEntryLength": 1000
  }
}